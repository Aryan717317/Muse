{
    "name": "muse-monorepo",
    "version": "0.0.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=apps/server\"",
        "build:web": "npm run build --workspace=apps/web",
        "build": "npm run build --workspaces"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}